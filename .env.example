# Copy to .env for local HTTP testing (never commit .env). On Railway, set these
# as service Variables instead.
#
# Two independent layers (do not conflate):
#   - Server -> Meta Graph API : META_ADS_ACCESS_TOKEN (a Meta System User token).
#   - Client -> this server    : MCP_BEARER_TOKEN (static bearer, required in HTTP mode).

# --- Layer 1: Meta access (read-only) ---
# A Meta System User access token with the ads_read scope. System User tokens
# are non-expiring. One token covers every ad account the System User is assigned
# to (e.g. NAN Properties + Tiara), so each tool just takes an act_<id> argument.
META_ADS_ACCESS_TOKEN=replace-with-meta-system-user-token

# Read-only by default. Set to "true" ONLY to expose the 19 write/lifecycle tools
# (create/update/delete/pause/resume). Not needed for analysis — leave it off.
# META_ADS_ENABLE_WRITE_TOOLS=false

# --- Layer 2: client access (single bearer token) ---
# REQUIRED in HTTP mode — the server refuses to start without it. A long random
# secret; whoever holds it can query your ad accounts, so treat it like a
# password. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_BEARER_TOKEN=replace-with-a-long-random-secret

# --- Transport ---
# "http" for remote/Railway. Omit (or "stdio") for a local client that spawns
# the binary directly.
TRANSPORT=http

# Railway injects PORT automatically; only set locally for a custom port.
# PORT=3000
